# Application
APP_ENV=development
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5173
BACKEND_PORT=3001

# Database
DATABASE_URL="mysql://root:@localhost:3306/deriv_platform"

# Session
SESSION_SECRET=your-session-secret-min-32-chars-change-me

# Encryption (32 bytes hex for AES-256)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Deriv OAuth
DERIV_APP_ID=your_deriv_app_id
DERIV_CLIENT_ID=your_deriv_client_id
DERIV_CLIENT_SECRET=your_deriv_client_secret_if_applicable
DERIV_AUTH_BASE_URL=https://oauth.deriv.com
DERIV_API_BASE_URL=https://api.derivws.com
DERIV_WS_PUBLIC_URL=wss://ws.derivws.com/websockets/v3

# OAuth Redirect
OAUTH_REDIRECT_URI=http://localhost:3001/api/auth/deriv/callback
